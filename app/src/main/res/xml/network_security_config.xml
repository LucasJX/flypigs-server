<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- ntfy 自建服务器大量使用局域网 HTTP，需要 ws:// 连接 -->
    <!-- 默认允许明文，但 App 在添加 http 服务器时会弹出安全提示 -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- HTTPS/WSS 连接优先：OkHttpClient 层面对 https/wss URL 优先选择 -->
</network-security-config>
